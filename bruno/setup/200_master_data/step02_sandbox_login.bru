meta {
  name: Step02 Sandbox API ログイン (POST /api/v1/auth/login)
  type: http
  seq: 2
}

post {
  url: {{apiScheme}}://{{apiHost}}:{{apiPort}}{{apiRoot}}/auth/login
  body: json
  auth: none
}

headers {
  Authorization: Bearer {{idToken}}
  Content-Type: application/json
}

body:json {
  {
    "email": "{{emailEncoded}}"
  }
}

assert {
  res.status: eq 200
  res.body.returnCode: eq 0
}
