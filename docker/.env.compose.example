# docker-compose.yml 用環境変数
# cp .env.compose.example .env.compose して実際の値を設定する
# 起動: docker compose --env-file .env.compose up -d

COMPOSE_PROJECT_NAME=sandbox

# MySQL
MYSQL_ROOT_PASSWORD=your_root_password
DB_SCHEMA=dbschema
DB_USER=dbuser
DB_PASSWORD=dbpassword
DB_PORT=23306       # ホスト側公開ポート（23306:3306）

# Redis
REDIS_PORT=26379    # ホスト側公開ポート（26379:6379）

# 初期管理者ユーザー（initdb.d/99_initialize_dml.sh で INSERT）
ADMIN_UUID=your_cognito_sub
ADMIN_EMAIL=your_admin_email@example.com
