# Bruno 環境設定（実際の接続情報）
bruno/environments/local.bru

# Docker 環境変数（実際の値）
docker/.env.compose

# Docker ボリュームマウント
local/*
!local/work/

# JMeter 環境変数（実際の値）
jmeter/jmeter.env
jmeter/jmeter.log
jmeter/result/*

# data: セキュリティ情報を含む CSV は除外（*.csv.example のみ管理対象）
data/admin_user.csv
data/user.csv
jmeter/data/*.csv

# ワーク内の一時ファイル
local/work/*
